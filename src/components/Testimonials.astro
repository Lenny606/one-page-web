---
const testimonials = [
    {
        quote: "NexaCore kompletně zmodernizoval naši zastaralou infrastrukturu. Systém je teď bleskově rychlý a my šetříme desítky hodin měsíčně na údržbě. Skvělý přístup a profesionalita.",
        name: "Petr Novák",
        role: "CTO, FinTech Innovate",
        avatar: "https://xsgames.co/randomusers/avatar.php?g=male",
        company: "FinTech Innovate",
    },
    {
        quote: "Potřebovali jsme rychle vyvinout komplexní SaaS platformu od nuly. NexaCore tým dodal první MVP za 8 týdnů. Naprostá pecka! Můžu jen a jen doporučit jejich expertní služby.",
        name: "Jana Dvořáková",
        role: "CEO & Founder, HealthSync",
        avatar: "https://xsgames.co/randomusers/avatar.php?g=female",
        company: "HealthSync",
    },
    {
        quote: "Migrace našich obrovských databází do cloudu přes noc s nulovým výpadkem pro zákazníky? Pro NexaCore to nebyl problém. Jsme nadšení z dlouhodobé spolupráce.",
        name: "Martin Svoboda",
        role: "Operations Director, E-Shop Plus",
        avatar: "https://xsgames.co/randomusers/avatar.php?g=male&k=1",
        company: "E-Shop Plus",
    },
];
---

<section
    id="reference"
    class="py-24 relative z-10 bg-white/5 border-y border-white/5 overflow-hidden"
>
    <!-- Decoration -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-64 bg-brand-blue/10 blur-[100px] rounded-full -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2
                class="text-brand-purple font-bold tracking-widest uppercase mb-2 text-sm"
            >
                Reference
            </h2>
            <h3 class="text-4xl md:text-5xl font-bold mb-6">
                Co o nás říkají <span class="text-gradient">klienti</span>
            </h3>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            {
                testimonials.map((test) => (
                    <div class="glass-card p-8 flex flex-col justify-between h-full relative">
                        <div class="text-6xl text-brand-purple/20 absolute top-4 right-6 font-serif leading-none">
                            "
                        </div>

                        <div class="mb-8 relative z-10">
                            <div class="flex gap-1 mb-4">
                                {[...Array(5)].map(() => (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                        class="w-5 h-5 text-yellow-500"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                ))}
                            </div>
                            <p class="text-white/80 leading-relaxed italic text-lg">
                                "{test.quote}"
                            </p>
                        </div>

                        <div class="flex items-center gap-4 border-t border-white/10 pt-6">
                            <img
                                src={test.avatar}
                                alt={test.name}
                                class="w-12 h-12 rounded-full border-2 border-brand-purple/50 object-cover"
                            />
                            <div>
                                <div class="font-bold text-white">
                                    {test.name}
                                </div>
                                <div class="text-sm text-white/50">
                                    {test.role}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
