---
---

<section
    id="kontakt"
    class="py-24 relative z-10 bg-white/5 border-y border-white/5 overflow-hidden"
>
    <div
        class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-brand-pink/10 to-transparent -z-10 blur-3xl"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16">
        <!-- Contact info -->
        <div>
            <h2
                class="text-brand-blue font-bold tracking-widest uppercase mb-2 text-sm"
            >
                Kontakt
            </h2>
            <h3 class="text-4xl md:text-5xl font-bold mb-6">
                Pojďme probrat <span class="text-gradient">váš projekt</span>
            </h3>
            <p class="text-lg text-white/70 mb-10">
                Nechte nám zprávu přes formulář, nebo se nám ozvěte přímo.
                Odpovídáme obvykle do 24 hodin a první konzultace je vždy
                zdarma.
            </p>

            <div class="space-y-6">
                <div class="flex items-center gap-4">
                    <div
                        class="w-12 h-12 rounded-full glass-card flex items-center justify-center text-brand-pink"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-white/50">Email</div>
                        <a
                            href="mailto:hello@nexacore.cz"
                            class="font-bold text-lg hover:text-brand-pink transition-colors"
                            >hello@nexacore.cz</a
                        >
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div
                        class="w-12 h-12 rounded-full glass-card flex items-center justify-center text-brand-blue"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.25-3.95-6.847-6.847l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-white/50">Telefon</div>
                        <a
                            href="tel:+420123456789"
                            class="font-bold text-lg hover:text-brand-blue transition-colors"
                            >+420 123 456 789</a
                        >
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div
                        class="w-12 h-12 rounded-full glass-card flex items-center justify-center text-brand-purple"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <div class="text-sm text-white/50">Kanceláře</div>
                        <div class="font-bold text-lg">
                            Inovační Hub, Praha 8
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <form
            class="glass-card p-8 flex flex-col gap-6"
            onsubmit="event.preventDefault(); alert('Vaše zpráva byla odeslána! (Demo)');"
        >
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-medium text-white/70 mb-2"
                        >Jméno a příjmení</label
                    >
                    <input
                        type="text"
                        id="name"
                        required
                        class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-brand-pink transition-colors placeholder:text-white/20"
                        placeholder="Jan Novák"
                    />
                </div>
                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-white/70 mb-2"
                        >Emailová adresa</label
                    >
                    <input
                        type="email"
                        id="email"
                        required
                        class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-brand-blue transition-colors placeholder:text-white/20"
                        placeholder="jan@firma.cz"
                    />
                </div>
            </div>

            <div>
                <label
                    for="service"
                    class="block text-sm font-medium text-white/70 mb-2"
                    >O jakou službu máte zájem?</label
                >
                <select
                    id="service"
                    class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-brand-purple transition-colors appearance-none"
                >
                    <option value="software">Vývoj Software na míru</option>
                    <option value="cloud">Cloud & DevOps</option>
                    <option value="security">Kybernetická bezpečnost</option>
                    <option value="ai">AI & Data Analytics</option>
                    <option value="other">Jiné / Chci poradit</option>
                </select>
            </div>

            <div>
                <label
                    for="message"
                    class="block text-sm font-medium text-white/70 mb-2"
                    >Vaše zpráva</label
                >
                <textarea
                    id="message"
                    rows="4"
                    required
                    class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-brand-purple transition-colors placeholder:text-white/20 resize-none"
                    placeholder="Popište nám ve zkratce vaši výzvu..."
                ></textarea>
            </div>

            <button
                type="submit"
                class="btn-primary w-full md:w-auto self-end mt-2"
            >
                Odeslat nezávaznou poptávku
            </button>

            <div class="text-xs text-center text-white/40 mt-2">
                Odesláním formuláře souhlasíte se zpracováním osobních údajů.
            </div>
        </form>
    </div>
</section>
