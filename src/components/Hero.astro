---
---

<section
    class="relative min-h-screen flex items-center justify-center pt-20 pb-20 px-6 overflow-hidden z-10"
>
    <div class="max-w-5xl mx-auto text-center relative z-10">
        <div
            class="inline-block mb-6 px-4 py-1.5 rounded-full border border-white/20 bg-white/5 backdrop-blur-md text-sm font-medium tracking-wide"
        >
            <span class="text-brand-blue flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-brand-blue animate-pulse"
                ></span>
                Nová generace IT služeb
            </span>
        </div>

        <h1
            class="text-5xl md:text-7xl font-extrabold mb-8 leading-tight tracking-tight"
        >
            Akcelerujte svůj růst s <br class="hidden md:block" />
            <span class="text-gradient">NexaCore platformou</span>
        </h1>

        <p
            class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-12 leading-relaxed"
        >
            Inovativní softwarová řešení a cloudová integrace pro moderní firmy,
            které chtějí dominovat v digitálním světě a automatizovat procesy.
        </p>

        <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
            <a
                href="#kontakt"
                class="btn-primary w-full sm:w-auto text-lg text-center"
            >
                Poptat řešení zdarma
            </a>
            <a
                href="#sluzby"
                class="px-8 py-3 rounded-full text-lg font-bold border border-white/20 hover:bg-white/10 transition-colors w-full sm:w-auto text-center"
            >
                Prozkoumat služby
            </a>
        </div>

        <!-- Stats / Trust indicators -->
        <div
            class="mt-20 pt-10 border-t border-white/10 flex flex-wrap justify-center gap-8 md:gap-20 text-center"
        >
            <div>
                <div class="text-3xl font-bold text-white mb-1">99.9%</div>
                <div class="text-sm text-white/50 uppercase tracking-widest">
                    Uptime platformy
                </div>
            </div>
            <div>
                <div class="text-3xl font-bold text-white mb-1">50+</div>
                <div class="text-sm text-white/50 uppercase tracking-widest">
                    Spokojených firem
                </div>
            </div>
            <div>
                <div class="text-3xl font-bold text-white mb-1">24/7</div>
                <div class="text-sm text-white/50 uppercase tracking-widest">
                    Expertní support
                </div>
            </div>
        </div>
    </div>

    <!-- Decorative elements -->
    <div
        class="absolute top-[40%] right-[10%] w-64 h-64 glass-card rounded-[3rem] rotate-12 -z-10 opacity-40 blur-sm hidden lg:block border-[0.5px]"
    >
    </div>
    <div
        class="absolute bottom-[20%] left-[10%] w-48 h-48 glass-card rounded-full -z-10 opacity-30 blur-[2px] hidden lg:block"
    >
    </div>
</section>
