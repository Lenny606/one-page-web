---
const services = [
    {
        title: "Vývoj Software na míru",
        description:
            "Designujeme, programujeme a nasazujeme robustní aplikace, které přesně odpovídají vašim firemním procesům.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
        color: "from-brand-purple to-brand-blue",
    },
    {
        title: "Cloud & DevOps Solutions",
        description:
            "Migrujeme vaši infrastrukturu do cloudu (AWS, Azure) a nastavujeme CI/CD pipeline pro maximální efektivitu.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>`,
        color: "from-brand-blue to-brand-pink",
    },
    {
        title: "Kybernetická bezpečnost",
        description:
            "Chráníme vaše data před moderními hrozbami. Provádíme bezpečnostní audity a zavádíme enterprise security standardy.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
        color: "from-brand-pink to-brand-purple",
    },
    {
        title: "AI & Data Analytics",
        description:
            "Pomocí strojového učení transformujeme vaše data na cenné byznysové insighty a automatizujeme rutinní agendu.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>`,
        color: "from-brand-blue to-teal-400",
    },
];
---

<section
    id="sluzby"
    class="py-24 relative z-10 bg-white/5 border-y border-white/5"
>
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2
                class="text-brand-pink font-bold tracking-widest uppercase mb-2 text-sm"
            >
                Naše Služby
            </h2>
            <h3 class="text-4xl md:text-5xl font-bold mb-6">
                Technologická podpora<br />pro <span class="text-gradient"
                    >váš byznys</span>
            </h3>
            <p class="text-lg text-white/70">
                Pokrýváme celý životní cyklus software. Od prvotní analýzy, přes
                architekturu a kód, až po deployment a následnou IT správu.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            {
                services.map((service, index) => (
                    <div class="glass-card p-8 group hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
                        <div
                            class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-br ${service.color} opacity-20 blur-3xl rounded-full group-hover:opacity-40 transition-opacity`}
                        />

                        <div
                            class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${service.color} flex items-center justify-center text-white mb-6 p-4 shadow-lg`}
                        >
                            <Fragment set:html={service.icon} />
                        </div>

                        <h4 class="text-2xl font-bold mb-3">{service.title}</h4>
                        <p class="text-white/70 leading-relaxed mb-6">
                            {service.description}
                        </p>

                        <a
                            href="#kontakt"
                            class="inline-flex items-center gap-2 text-sm font-bold text-white/90 hover:text-white group-hover:gap-3 transition-all"
                        >
                            Více informací
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                class="w-4 h-4 text-brand-blue"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                                />
                            </svg>
                        </a>
                    </div>
                ))
            }
        </div>
    </div>
</section>
