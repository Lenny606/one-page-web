---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 py-12 relative z-10 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-8 mb-12">
            <!-- Brand -->
            <div class="md:col-span-1">
                <a
                    href="#"
                    class="text-2xl font-bold flex items-center gap-2 mb-4"
                >
                    <div
                        class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-blue to-brand-purple flex items-center justify-center font-black text-white"
                    >
                        N
                    </div>
                    <span>NexaCore</span>
                </a>
                <p class="text-sm text-white/50 leading-relaxed">
                    Přední technologický partner pro inovativní firmy. Od návrhu
                    po údržbu.
                </p>
            </div>

            <!-- Quick links -->
            <div>
                <h4 class="font-bold mb-4">Mapa stránek</h4>
                <ul class="space-y-2 text-sm text-white/60">
                    <li>
                        <a
                            href="#o-nas"
                            class="hover:text-white transition-colors">O nás</a>
                    </li>
                    <li>
                        <a
                            href="#sluzby"
                            class="hover:text-white transition-colors"
                            >Služby</a>
                    </li>
                    <li>
                        <a
                            href="#benefity"
                            class="hover:text-white transition-colors"
                            >Benefity</a>
                    </li>
                    <li>
                        <a
                            href="#reference"
                            class="hover:text-white transition-colors"
                            >Reference</a>
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="font-bold mb-4">Právní informace</h4>
                <ul class="space-y-2 text-sm text-white/60">
                    <li>
                        <a href="#" class="hover:text-white transition-colors"
                            >Obchodní podmínky</a>
                    </li>
                    <li>
                        <a href="#" class="hover:text-white transition-colors"
                            >GDPR a Ochrana osobních údajů</a>
                    </li>
                    <li>
                        <a href="#" class="hover:text-white transition-colors"
                            >Cookies politika</a>
                    </li>
                </ul>
            </div>

            <!-- Company details -->
            <div>
                <h4 class="font-bold mb-4">Firemní údaje</h4>
                <ul class="space-y-2 text-sm text-white/60">
                    <li>NexaCore s.r.o.</li>
                    <li>IČO: 12345678</li>
                    <li>DIČ: CZ12345678</li>
                    <li>Společnost je zapsaná u Městského soudu v Praze.</li>
                </ul>
            </div>
        </div>

        <!-- Copyright & Socials -->
        <div
            class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4"
        >
            <div class="text-sm text-white/40">
                &copy; {currentYear} NexaCore s.r.o. Všechna práva vyhrazena.
            </div>

            <div class="flex gap-4">
                <!-- Social icons (examples) -->
                <a
                    href="#"
                    class="text-white/40 hover:text-white transition-colors"
                    aria-label="LinkedIn"
                >
                    <svg
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        class="h-5 w-5"
                        aria-hidden="true"
                        ><path
                            fill-rule="evenodd"
                            d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.253 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.253 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z"
                            clip-rule="evenodd"></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-white/40 hover:text-white transition-colors"
                    aria-label="Twitter"
                >
                    <svg
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        class="h-5 w-5"
                        aria-hidden="true"
                        ><path
                            d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>
